# ===========================================
# 이동반 출석부 - Netlify 환경 변수 (env.example)
# Netlify 대시보드 > Site settings > Environment variables 에서 설정
# ===========================================

# ---- Google Sheets API (필수) ----
# 서비스 계정 JSON 전체 내용을 한 줄로 (줄바꿈은 \n으로)
# 또는 아래 두 개로 분리해서 넣어도 됨
GOOGLE_SERVICE_ACCOUNT_JSON=

# 분리 입력 시 (GOOGLE_SERVICE_ACCOUNT_JSON 대신 사용 가능)
# GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 관리자가 만든 출석부용 스프레드시트 ID (선택, 관리자 페이지에서 URL로 덮어쓸 수 있음)
# SPREADSHEET_ID=

# 교사별 시간표/과목/출석 검색용 DB 시트 (권장). 설정 시 교사가 입력한 URL이 아닌 이 시트에서만 조회·저장함.
# 관리자가 "DB 제작"한 스프레드시트 ID를 넣으면, 교사가 다른 주소를 입력해도 항상 이 시트 기준으로 시간표가 검색됨.
# ADMIN_DB_SPREADSHEET_ID=

# ---- Firebase (교사 이름 유지·구글 로그인, 선택) ----
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ---- 기타 ----
# CORS 허용 오리진 (필요 시)
# ALLOWED_ORIGINS=https://your-site.netlify.app
